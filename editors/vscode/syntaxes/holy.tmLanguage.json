{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Holy",
    "scopeName": "source.holy",
    "fileTypes": ["holy"],
    "patterns": [
        { "include": "#comment" },
        { "include": "#string" },
        { "include": "#salm-method-generic-def" },
        { "include": "#salm-generic-def" },
        { "include": "#salm-method-def" },
        { "include": "#salm-def" },
        { "include": "#scripture-generic-def" },
        { "include": "#scripture-def" },
        { "include": "#covenant-generic-def" },
        { "include": "#sin-def" },
        { "include": "#covenant-def" },
        { "include": "#hail-call" },
        { "include": "#manifest-variant-call" },
        { "include": "#manifest-call" },
        { "include": "#testament-decl" },
        { "include": "#answer-for" },
        { "include": "#discern-branch" },
        { "include": "#field-access" },
        { "include": "#multiword-cmp" },
        { "include": "#multiword-decl" },
        { "include": "#multiword-handler" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#reveals-type" },
        { "include": "#builtin-type" },
        { "include": "#builtin-covenant-variant" },
        { "include": "#keyword-context-marker" },
        { "include": "#keyword-exception" },
        { "include": "#keyword-control" },
        { "include": "#keyword-control-loop" },
        { "include": "#keyword-control-bearing" },
        { "include": "#keyword-declaration" },
        { "include": "#of-type" },
        { "include": "#storage-type" },
        { "include": "#keyword-operator" },
        { "include": "#variable-language" },
        { "include": "#keyword-other" }
    ],
    "repository": {

        "comment": {
            "name": "comment.line.double-dash.holy",
            "match": "--.*$"
        },

        "string": {
            "name": "string.quoted.double.holy",
            "begin": "\"",
            "end": "\""
        },

        "number": {
            "name": "constant.numeric.holy",
            "match": "-?\\b\\d+(\\.\\d+)?\\b"
        },

        "boolean": {
            "name": "constant.language.boolean.holy",
            "match": "\\b(blessed|forsaken)\\b"
        },

        "builtin-type": {
            "comment": "Built-in type keywords: generic built-ins and built-in covenants",
            "name": "support.type.holy",
            "match": "\\b(grace|verdict|legion)\\b"
        },

        "reveals-type": {
            "comment": "reveals <Type> — keep return types highlighted directly after reveals",
            "match": "\\b(reveals)\\s+(atom|fractional|word|dogma|void|grace|verdict|legion|[a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.declaration.holy" },
                "2": { "name": "entity.name.type.holy" }
            }
        },

        "builtin-covenant-variant": {
            "comment": "Built-in covenant variant keywords: granted/absent (grace) and righteous/condemned (verdict)",
            "name": "support.constant.holy",
            "match": "\\b(granted|absent|righteous|condemned)\\b"
        },

        "keyword-context-marker": {
            "comment": "'after' opens a grouped sub-expression; 'thus' closes any open context (type arg, arg list, or grouping)",
            "name": "keyword.control.grouping.holy",
            "match": "\\b(after|thus)\\b"
        },

        "salm-method-generic-def": {
            "comment": "salm name upon ScriptureType of T, E — method salm with type params",
            "match": "\\b(salm)\\s+([a-zA-Z_]\\w*)\\s+(upon)\\s+([a-zA-Z_]\\w*)\\s+(of)\\s+([A-Z][A-Za-z_]*(?:\\s*,\\s*[A-Z][A-Za-z_]*)*)",
            "captures": {
                "1": { "name": "keyword.declaration.function.holy" },
                "2": { "name": "entity.name.function.holy" },
                "3": { "name": "keyword.other.holy" },
                "4": { "name": "entity.name.type.holy" },
                "5": { "name": "keyword.other.holy" },
                "6": { "name": "variable.type.parameter.holy" }
            }
        },

        "salm-generic-def": {
            "comment": "salm name of T, E — generic salm declaration; type params highlighted",
            "match": "\\b(salm)\\s+([a-zA-Z_]\\w*)\\s+(of)\\s+([A-Z][A-Za-z_]*(?:\\s*,\\s*[A-Z][A-Za-z_]*)*)",
            "captures": {
                "1": { "name": "keyword.declaration.function.holy" },
                "2": { "name": "entity.name.function.holy" },
                "3": { "name": "keyword.other.holy" },
                "4": { "name": "variable.type.parameter.holy" }
            }
        },

        "salm-method-def": {
            "comment": "salm name upon ScriptureType",
            "match": "\\b(salm)\\s+([a-zA-Z_]\\w*)\\s+(upon)\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.declaration.function.holy" },
                "2": { "name": "entity.name.function.holy" },
                "3": { "name": "keyword.other.holy" },
                "4": { "name": "entity.name.type.holy" }
            }
        },

        "salm-def": {
            "comment": "salm name",
            "match": "\\b(salm)\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.declaration.function.holy" },
                "2": { "name": "entity.name.function.holy" }
            }
        },

        "scripture-generic-def": {
            "comment": "scripture Name of T, E — generic scripture with type params",
            "match": "\\b(scripture)\\s+([a-zA-Z_]\\w*)\\s+(of)\\s+([A-Z][A-Za-z_]*(?:\\s*,\\s*[A-Z][A-Za-z_]*)*)",
            "captures": {
                "1": { "name": "keyword.declaration.class.holy" },
                "2": { "name": "entity.name.type.holy" },
                "3": { "name": "keyword.other.holy" },
                "4": { "name": "variable.type.parameter.holy" }
            }
        },

        "scripture-def": {
            "match": "\\b(scripture)\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.declaration.class.holy" },
                "2": { "name": "entity.name.type.holy" }
            }
        },

        "covenant-generic-def": {
            "comment": "covenant Name of T, E — generic covenant with type params",
            "match": "\\b(covenant)\\s+([a-zA-Z_]\\w*)\\s+(of)\\s+([A-Z][A-Za-z_]*(?:\\s*,\\s*[A-Z][A-Za-z_]*)*)",
            "captures": {
                "1": { "name": "keyword.declaration.class.holy" },
                "2": { "name": "entity.name.type.holy" },
                "3": { "name": "keyword.other.holy" },
                "4": { "name": "variable.type.parameter.holy" }
            }
        },

        "sin-def": {
            "match": "\\b(sin)\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.control.exception.holy" },
                "2": { "name": "entity.name.type.holy" }
            }
        },

        "covenant-def": {
            "match": "\\b(covenant)\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.declaration.class.holy" },
                "2": { "name": "entity.name.type.holy" }
            }
        },

        "hail-call": {
            "comment": "hail salmName — function/method call invocation",
            "match": "\\b(hail)\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.other.invocation.holy" },
                "2": { "name": "entity.name.function.holy" }
            }
        },

        "manifest-variant-call": {
            "comment": "manifest Variant of CovenantName — data variant instantiation",
            "match": "\\b(manifest)\\s+([a-zA-Z_]\\w*)\\s+(of)\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.other.invocation.holy" },
                "2": { "name": "support.constant.holy" },
                "3": { "name": "keyword.other.holy" },
                "4": { "name": "entity.name.type.holy" }
            }
        },

        "manifest-call": {
            "comment": "manifest ScriptureName — scripture instantiation",
            "match": "\\b(manifest)\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.other.invocation.holy" },
                "2": { "name": "entity.name.type.holy" }
            }
        },

        "testament-decl": {
            "match": "\\b(testament)\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.control.import.holy" },
                "2": { "name": "entity.name.namespace.holy" }
            }
        },

        "answer-for": {
            "match": "\\b(answer\\s+for)\\s+([a-zA-Z_]\\w+)(?:\\s+(as)\\s+([a-zA-Z_]\\w*))?",
            "captures": {
                "1": { "name": "keyword.control.holy" },
                "2": { "name": "entity.name.type.holy" },
                "3": { "name": "keyword.other.holy" },
                "4": { "name": "variable.other.holy" }
            }
        },

        "discern-branch": {
            "match": "\\b(as)\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.other.holy" },
                "2": { "name": "entity.name.type.holy" }
            }
        },

        "multiword-cmp": {
            "comment": "Multi-word comparison operators — order matters",
            "patterns": [
                {
                    "name": "keyword.operator.comparison.holy",
                    "match": "\\bno\\s+greater\\s+than\\b"
                },
                {
                    "name": "keyword.operator.comparison.holy",
                    "match": "\\bno\\s+lesser\\s+than\\b"
                },
                {
                    "name": "keyword.operator.comparison.holy",
                    "match": "\\bgreater\\s+than\\b"
                },
                {
                    "name": "keyword.operator.comparison.holy",
                    "match": "\\blesser\\s+than\\b"
                },
                {
                    "name": "keyword.operator.comparison.holy",
                    "match": "\\bis\\s+not\\b"
                }
            ]
        },

        "multiword-decl": {
            "patterns": [
                {
                    "name": "keyword.declaration.holy",
                    "match": "\\blet\\s+there\\s+be\\b"
                },
                {
                    "name": "keyword.declaration.holy",
                    "match": "\\blet\\s+there\\b"
                },
                {
                    "name": "keyword.control.holy",
                    "match": "\\blitany\\s+for\\b"
                },
                {
                    "name": "keyword.control.holy",
                    "match": "\\botherwise\\s+so\\b"
                }
            ]
        },

        "multiword-handler": {
            "patterns": [
                {
                    "name": "keyword.control.holy",
                    "match": "\\banswer\\s+for\\b"
                }
            ]
        },

        "field-access": {
            "comment": "field from its|obj — its must come first so it isn't swallowed by the generic identifier alternative",
            "match": "\\b([a-zA-Z_]\\w*)\\s+(from)\\s+(?:(its)\\b|([a-zA-Z_]\\w*))",
            "captures": {
                "1": { "name": "variable.other.holy" },
                "2": { "name": "keyword.other.holy" },
                "3": { "name": "variable.language.holy" },
                "4": { "name": "variable.other.holy" }
            }
        },

        "keyword-exception": {
            "comment": "transgress — throw; blood-red scope shared with sin declaration",
            "name": "keyword.control.exception.holy",
            "match": "\\b(transgress)\\b"
        },

        "keyword-control": {
            "name": "keyword.control.holy",
            "match": "\\b(whether|otherwise|confess|absolve|reveal|discern|amen)\\b"
        },

        "keyword-control-loop": {
            "comment": "Loop control: forsake = break, ascend = continue",
            "name": "keyword.control.flow.holy",
            "match": "\\b(forsake|ascend)\\b"
        },

        "keyword-control-bearing": {
            "comment": "bearing — binds covenant variant fields in a discern branch",
            "name": "keyword.control.holy",
            "match": "\\bbearing\\b"
        },

        "keyword-declaration": {
            "name": "keyword.declaration.holy",
            "match": "\\b(become|be|receiving|reveals|revealing|covenant)\\b"
        },

        "storage-type": {
            "name": "storage.type.holy",
            "match": "\\b(atom|fractional|word|dogma|void)\\b"
        },

        "keyword-operator": {
            "name": "keyword.operator.holy",
            "match": "\\b(plus|minus|times|over|remainder|negate|is|and)\\b"
        },

        "variable-language": {
            "name": "variable.language.holy",
            "match": "\\b(its)\\b"
        },

        "of-type": {
            "comment": "of <CustomType> — highlights custom type names; excludes primitives, builtins, and context markers",
            "match": "\\b(of)\\s+(?!atom\\b|fractional\\b|word\\b|dogma\\b|void\\b|grace\\b|verdict\\b|legion\\b|after\\b|thus\\b)([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "keyword.other.holy" },
                "2": { "name": "entity.name.type.holy" }
            }
        },

        "keyword-other": {
            "name": "keyword.other.holy",
            "match": "\\b(praying|upon|from|of|as|no|not|greater|lesser|than)\\b"
        }

    }
}
