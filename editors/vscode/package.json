{
    "name": "holy-script",
    "displayName": "Holy Script",
    "description": "Syntax highlighting, snippets, file icons and run support for Holy Script",
    "version": "0.2.0",
    "publisher": "Gaok1",
    "icon": "icon.png",
    "license": "MIT",
    "engines": { "vscode": "^1.75.0" },
    "categories": ["Programming Languages"],
    "keywords": ["holy", "holy-script", "holyscript"],
    "repository": {
        "type": "git",
        "url": "https://github.com/Gaok1/holy-script"
    },
    "main": "./extension.js",
    "activationEvents": [
        "onLanguage:holy"
    ],
    "contributes": {
        "commands": [
            {
                "command": "holy.runFile",
                "title": "Run Holy Script",
                "icon": "$(play)"
            }
        ],
        "menus": {
            "editor/title/run": [
                {
                    "command": "holy.runFile",
                    "when": "resourceExtname == '.holy'",
                    "group": "navigation"
                }
            ]
        },
        "languages": [
            {
                "id": "holy",
                "aliases": ["Holy", "holy-lang"],
                "extensions": [".holy"],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "holy",
                "scopeName": "source.holy",
                "path": "./syntaxes/holy.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "holy",
                "path": "./snippets/holy.json"
            }
        ],
        "iconThemes": [
            {
                "id": "holy-icons",
                "label": "Holy Language Icons",
                "path": "./holy-icon-theme.json"
            }
        ],
        "configurationDefaults": {
            "code-runner.executorMap": {
                "holy": "holy"
            },
            "editor.tokenColorCustomizations": {
                "textMateRules": [
                    {
                        "scope": "comment.line.double-dash.holy",
                        "settings": { "foreground": "#5A7A52", "fontStyle": "italic" }
                    },
                    {
                        "scope": "string.quoted.double.holy",
                        "settings": { "foreground": "#C9AA7C" }
                    },
                    {
                        "scope": "constant.numeric.holy",
                        "settings": { "foreground": "#C9A84C" }
                    },
                    {
                        "scope": "constant.language.boolean.holy",
                        "settings": { "foreground": "#E8C060", "fontStyle": "bold" }
                    },
                    {
                        "scope": "storage.type.holy",
                        "settings": { "foreground": "#6CA0DC" }
                    },
                    {
                        "scope": "support.type.holy",
                        "settings": { "foreground": "#4EC9B0" }
                    },
                    {
                        "scope": "support.constant.holy",
                        "settings": { "foreground": "#C3A96E", "fontStyle": "italic" }
                    },
                    {
                        "scope": "entity.name.type.holy",
                        "settings": { "foreground": "#E0C896", "fontStyle": "italic" }
                    },
                    {
                        "scope": "entity.name.function.holy",
                        "settings": { "foreground": "#FFD966" }
                    },
                    {
                        "scope": "entity.name.namespace.holy",
                        "settings": { "foreground": "#D4B060" }
                    },
                    {
                        "scope": "variable.language.holy",
                        "settings": { "foreground": "#9CDCFE", "fontStyle": "italic" }
                    },
                    {
                        "scope": "variable.other.holy",
                        "settings": { "foreground": "#D4D4D4" }
                    },
                    {
                        "scope": "variable.type.parameter.holy",
                        "settings": { "foreground": "#B088D0", "fontStyle": "italic" }
                    },
                    {
                        "scope": "keyword.other.invocation.holy",
                        "settings": { "foreground": "#E8A830", "fontStyle": "bold" }
                    },
                    {
                        "scope": "keyword.control.import.holy",
                        "settings": { "foreground": "#C9A84C" }
                    },
                    {
                        "scope": "keyword.declaration.function.holy",
                        "settings": { "foreground": "#C9A84C", "fontStyle": "bold" }
                    },
                    {
                        "scope": "keyword.declaration.class.holy",
                        "settings": { "foreground": "#B8950A" }
                    },
                    {
                        "scope": "keyword.declaration.holy",
                        "settings": { "foreground": "#B09030" }
                    },
                    {
                        "scope": "keyword.control.holy",
                        "settings": { "foreground": "#C49A3C" }
                    },
                    {
                        "scope": "keyword.control.flow.holy",
                        "settings": { "foreground": "#D4875A" }
                    },
                    {
                        "scope": "keyword.control.grouping.holy",
                        "settings": { "foreground": "#7B9BAD" }
                    },
                    {
                        "scope": "keyword.control.exception.holy",
                        "settings": { "foreground": "#C0392B", "fontStyle": "bold" }
                    },
                    {
                        "scope": "keyword.control.bearing.holy",
                        "settings": { "foreground": "#C49A3C", "fontStyle": "italic" }
                    },
                    {
                        "scope": "keyword.operator.holy",
                        "settings": { "foreground": "#A0A0A0" }
                    },
                    {
                        "scope": "keyword.operator.comparison.holy",
                        "settings": { "foreground": "#C0B080" }
                    },
                    {
                        "scope": "keyword.other.holy",
                        "settings": { "foreground": "#8A7A5A" }
                    }
                ]
            }
        }
    }
}
